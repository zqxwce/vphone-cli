<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Custom AudioServerPlugIn that impersonates Apple's VirtualAudio HAL
	     plugin so the iOS routing layer (vaem / FigVAEndpointManager) adopts it
	     and publishes a system-wide audio route for ALL apps. Backed by a
	     software-clocked virtual output device; rendered PCM is tapped and sent
	     to the host over the vphone audio relay. Replaces the stock
	     /System/Library/Audio/Plug-Ins/HAL/VirtualAudio.plugin (which needs
	     real audio-codec hardware the VM lacks). See research/audio/. -->
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleExecutable</key>
	<string>vphone_vaudio</string>
	<!-- VirtualAudio bundle id: vaem's TranslateBundleID looks up exactly this id
	     (FigVAEndpointManagerCreate -> _vaemGetVirtualAudioPlugin). With the .driver
	     extension fix the plugin now loads + Initializes without the old HAL-server
	     activation crash, so we can finally let vaem adopt our device and (if vadInit
	     completes) publish a system-wide AVAudioSession route for ALL apps. -->
	<key>CFBundleIdentifier</key>
	<string>com.apple.audio.CoreAudio.VirtualAudio</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>VirtualAudio</string>
	<key>CFBundlePackageType</key>
	<string>BNDL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>CFBundleSupportedPlatforms</key>
	<array>
		<string>iPhoneOS</string>
	</array>
	<key>MinimumOSVersion</key>
	<string>26.5</string>
	<key>UIDeviceFamily</key>
	<array>
		<integer>1</integer>
	</array>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64e</string>
	</array>
	<!-- AudioServerPlugIn registration: factory function returns the
	     AudioServerPlugInDriverInterface. The CFPlugInTypes UUID is the
	     well-known kAudioServerPlugInTypeUUID. -->
	<key>CFPlugInFactories</key>
	<dict>
		<key>F8BB1C28-BAE8-11D6-9C31-00039315CD46</key>
		<string>VPhoneVAudio_Create</string>
	</dict>
	<key>CFPlugInTypes</key>
	<dict>
		<key>443ABAB8-E7B3-491A-B985-BEB9187030DB</key>
		<array>
			<string>F8BB1C28-BAE8-11D6-9C31-00039315CD46</string>
		</array>
	</dict>
</dict>
</plist>
